#!/usr/bin/with-contenv bashio
set -euo pipefail

OPTIONS_PATH=/data/options.json
DEFAULT_BOOKDROP_FOLDER=grimmory/bookdrop
DEFAULT_BOOKS_FOLDER=grimmory/books

json_value() {
    jq -r "$1 // empty" "$OPTIONS_PATH"
}

validate_relative_path() {
    local path_value=$1
    local label=$2
    local root=$3

    case "$path_value" in
        /*|*..*)
            bashio::exit.nok "${label} must be relative to ${root}."
            ;;
    esac
}

BOOKDROP_FOLDER=$(json_value '.bookdrop_folder' || true)
BOOKS_FOLDER=$(json_value '.books_folder' || true)

BOOKDROP_FOLDER=${BOOKDROP_FOLDER:-$DEFAULT_BOOKDROP_FOLDER}
BOOKS_FOLDER=${BOOKS_FOLDER:-$DEFAULT_BOOKS_FOLDER}

validate_relative_path "$BOOKDROP_FOLDER" "bookdrop_folder" "/share"
validate_relative_path "$BOOKS_FOLDER" "books_folder" "/share"

mkdir -p /data /app /run/grimmory
mkdir -p "/share/$BOOKDROP_FOLDER"
mkdir -p "/share/$BOOKS_FOLDER"

# Ensure Grimmory's default app data path is writable by redirecting it to /data.
rm -rf /app/data
ln -s /data /app/data

rm -rf /bookdrop /books
ln -s "/share/$BOOKDROP_FOLDER" /bookdrop
ln -s "/share/$BOOKS_FOLDER" /books

bashio::log.info "Prepared Grimmory bookdrop at /share/${BOOKDROP_FOLDER}"
bashio::log.info "Prepared Grimmory books folder at /share/${BOOKS_FOLDER}"